{
  "name": "opencode-deveco",
  "version": "0.1.0",
  "description": "OpenCode plugin that brings DevEco Code (Huawei) account login and model access to standard opencode.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "exports": {
    "./server": "./dist/index.js",
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "opencode": ">=1.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "deveco",
    "huawei",
    "harmonyos",
    "ai-sdk"
  ]
}
