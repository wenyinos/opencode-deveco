{
  "name": "opencode-deveco",
  "version": "0.1.0",
  "description": "OpenCode plugin that brings DevEco Code (Huawei) account login and model access to standard opencode.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "exports": {
    "./server": "./dist/index.js",
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "opencode": ">=1.0.0"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "clean": "node -e \"import('fs').then(f=>f.rmSync('dist',{recursive:true,force:true}))\""
  },
  "dependencies": {
    "@opencode-ai/plugin": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "deveco",
    "huawei",
    "harmonyos",
    "ai-sdk"
  ]
}
